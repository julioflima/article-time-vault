flowchart TD
    F["📄 Arquivo F"] --> enc
    T["⏱️ Tempo alvo T<br>(anos)"] --> diff
    t0["📅 Ano de criação t₀"] --> diff

    diff["Passo 1: Calcular dificuldade<br>n = B(t₀, $1M) + ⌊log₂(T × 365)⌋"]

    diff --> seed["Passo 2: Gerar semente<br>S ← {0,1}ⁿ"]

    seed --> hash["Passo 3: Verificação<br>V ← HMAC-SHA256(S, n)"]

    hash --> key["Passo 4: Derivar chave<br>K ← HMAC-SHA256(S, V)"]

    key --> enc["Passo 5: Encriptar<br>C ← AES-256-GCM(K, F)"]

    enc --> pub["Passo 6: Publicar<br>(C, n, V)"]

    pub --> atk

    subgraph "&nbsp;&nbsp;"
        atk["Atacante testa<br>S' ∈ {0,1}ⁿ"]
        atk --> hashcheck["HMAC-SHA256(S', n) =? V"]
        hashcheck --> check{"Hash<br>válido?"}
        check -->|Não| atk
    end

    check -->|Sim| found["✅ S' é a solução"]

    found --> deriveK

    subgraph "&nbsp;"
        deriveK["K ← HMAC-SHA256(S', V)"]
        deriveK --> decfile["F ← AES-256-GCM.Dec(K, C)"]
    end

    decfile --> result["📄 Arquivo revelado"]

    style F fill:#d9d9d9,stroke:#666,color:#000
    style T fill:#bfbfbf,stroke:#666,color:#000
    style t0 fill:#bfbfbf,stroke:#666,color:#000
    style diff fill:#e6e6e6,stroke:#888,color:#000
    style seed fill:#e6e6e6,stroke:#888,color:#000
    style hash fill:#e6e6e6,stroke:#888,color:#000
    style key fill:#e6e6e6,stroke:#888,color:#000
    style enc fill:#e6e6e6,stroke:#888,color:#000
    style pub fill:#fff,stroke:#333,color:#000
    style atk fill:#999,stroke:#555,color:#000
    style hashcheck fill:#999,stroke:#555,color:#000
    style check fill:#ccc,stroke:#555,color:#000
    style found fill:#fff,stroke:#333,color:#000
    style deriveK fill:#d9d9d9,stroke:#666,color:#000
    style decfile fill:#d9d9d9,stroke:#666,color:#000
    style result fill:#fff,stroke:#333,color:#000
