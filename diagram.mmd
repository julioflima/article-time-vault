flowchart TD
    F["📄 Arquivo F"] --> enc
    T["⏱️ Tempo alvo T<br>(anos)"] --> diff
    t0["📅 Ano de criação t₀"] --> diff

    diff["Passo 1: Calcular dificuldade<br>n = B(t₀, $1M) + ⌊log₂(T × 365)⌋"]

    diff --> seed["Passo 2: Gerar semente<br>S ← {0,1}ⁿ"]

    seed --> hash["Passo 3: Verificação<br>V ← HMAC-SHA256(S, n)"]

    hash --> key["Passo 4: Derivar chave<br>K ← HMAC-SHA256(S, V)"]

    key --> enc["Passo 5: Encriptar<br>C ← AES-256-GCM(K, F)"]

    enc --> pub["Passo 6: Publicar<br>(C, n, V)"]

    pub --> atk

    subgraph "&nbsp;&nbsp;"
        atk["Atacante testa<br>S' ∈ {0,1}ⁿ"]
        atk --> hashcheck["HMAC-SHA256(S', n) =? V"]
        hashcheck --> check{"Hash<br>válido?"}
        check -->|Não| atk
    end

    check -->|Sim| found["✅ S' é a solução"]

    found --> deriveK

    subgraph "&nbsp;"
        deriveK["K ← HMAC-SHA256(S', V)"]
        deriveK --> decfile["F ← AES-256-GCM.Dec(K, C)"]
    end

    decfile --> result["📄 Arquivo revelado"]

    style F fill:#4a9eff,stroke:#2d7ad4,color:#fff
    style T fill:#ff9f43,stroke:#d48a2d,color:#fff
    style t0 fill:#ff9f43,stroke:#d48a2d,color:#fff
    style diff fill:#a55eea,stroke:#8044c4,color:#fff
    style seed fill:#a55eea,stroke:#8044c4,color:#fff
    style hash fill:#a55eea,stroke:#8044c4,color:#fff
    style key fill:#a55eea,stroke:#8044c4,color:#fff
    style enc fill:#a55eea,stroke:#8044c4,color:#fff
    style pub fill:#26de81,stroke:#1ba85e,color:#fff
    style atk fill:#fc5c65,stroke:#c44040,color:#fff
    style hashcheck fill:#fc5c65,stroke:#c44040,color:#fff
    style check fill:#fed330,stroke:#d4b320,color:#333
    style found fill:#26de81,stroke:#1ba85e,color:#fff
    style deriveK fill:#45aaf2,stroke:#2d7ad4,color:#fff
    style decfile fill:#45aaf2,stroke:#2d7ad4,color:#fff
    style result fill:#26de81,stroke:#1ba85e,color:#fff
    style atk2 fill:transparent,stroke:transparent,color:transparent
